cabal-version: 3.0
name: foo
version: 0.1.0.0
build-type: Simple

library
  default-language: Haskell2010
  hs-source-dirs: src
  exposed-modules: MyLib
  build-depends: base

executable foo
  default-language: Haskell2010
  hs-source-dirs: app
  main-is: Main.hs
  build-depends: base, foo

executable bar
  default-language: Haskell2010
  hs-source-dirs: bar
  main-is: Main.hs
  build-depends: base, foo
  build-tool-depends: foo:foo
