cabal-version:      3.0
name:               exe-test
version:            0.1.0.0
license:            BSD-3-Clause
build-type:         Simple

executable exe
    hs-source-dirs:   app
    main-is:          Main.hs
    build-depends:    base
    default-language: Haskell2010

test-suite test
    type:             exitcode-stdio-1.0
    hs-source-dirs:   test
    main-is:          Main.hs
    build-depends:    base
    default-language: Haskell2010
