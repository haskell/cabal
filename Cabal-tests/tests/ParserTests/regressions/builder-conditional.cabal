cabal-version: 3.18
name:          builder-conditional
version:       0
synopsis:      The builder(...) conditional demo
build-type:    Simple

library
  default-language: Haskell2010
  exposed-modules:  B

  if builder(cabal >= 3.18)
    ghc-options: -O2
  elif builder(mcabal)
    ghc-options: -O0
  else
    buildable: False

  -- Unknown tools are accepted and parse to OtherBuildTool.
  if builder(frobnicate >= 1.0)
    cpp-options: -DFROB
