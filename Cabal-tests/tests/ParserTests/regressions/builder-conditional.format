cabal-version: 3.18
name:          builder-conditional
version:       0
synopsis:      The builder(...) conditional demo
build-type:    Simple

library
    exposed-modules:  B
    default-language: Haskell2010

    if builder(cabal >=3.18)
        ghc-options: -O2

    else
        if builder(mcabal >=0)
            ghc-options: -O0

        else
            buildable: False

    if builder(frobnicate >=1.0)
        cpp-options: -DFROB
